rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /siteContent/homepageSlideshow {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /siteContent/globalEmergencyBanner {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /scheduledBanners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
