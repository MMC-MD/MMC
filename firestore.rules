rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Homepage slideshow slides
    match /siteContent/homepageSlideshow {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Global emergency banner
    match /siteContent/globalEmergencyBanner {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Scheduled banners (includes weekend calendar banners)
    match /scheduledBanners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
